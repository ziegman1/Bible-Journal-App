# Copy to .env.local for development. Add the same keys in Vercel → Settings → Environment Variables.
# Store / TestFlight / Play: FINAL_SUBMISSION_CHECKLIST.md (repo root)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical site URL (metadata, invites, Open Graph, share footers). No trailing slash.
# Production example: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public support address (footer, policies). If unset, the app uses support@badwr.app from site-config.
# NEXT_PUBLIC_SUPPORT_EMAIL=support@badwr.app

# Branding, legal templates, and copy defaults live in src/lib/site-config.ts

# Optional — SOAPS / prayer / share / BADWR week boundary (Sun 00:00–Sat, calendar in this TZ). Default: America/Chicago
# NEXT_PUBLIC_PILLAR_WEEK_TIMEZONE=America/New_York

# Optional — Ask AI
# OPENAI_API_KEY=

# Optional — group invite emails (Resend)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=

# Optional — Capacitor native shell: override WebView URL (defaults to NEXT_PUBLIC_SITE_URL, then VERCEL_URL)
# CAPACITOR_SERVER_URL=https://your-production-domain.com
# CAPACITOR_APP_ID=app.logosflow.biblejournal
# CAPACITOR_APP_NAME=BADWR
