# Copy to .env.local for development. Add the same keys in Vercel → Settings → Environment Variables.
# Store / TestFlight / Play: FINAL_SUBMISSION_CHECKLIST.md (repo root)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical site URL (metadata, invites, Open Graph, share footers). No trailing slash.
# Production: https://www.badwr.app (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public support address (footer, policies). If unset, the app uses support@badwr.app from site-config.
# NEXT_PUBLIC_SUPPORT_EMAIL=support@badwr.app

# Branding, legal templates, and copy defaults live in src/lib/site-config.ts

# Hidden /scripture module — see src/lib/scripture-module/access.ts
# Add these to .env.local in THIS repo root (same folder as package.json). If they are missing there,
# Next.js will not load them — /scripture will deny access even if you set them in another file or editor buffer.
# Custom keys use dynamic lookups in code; the file must still contain the variables below.
# Production: comma-separated allowlist (fail closed if unset). Non-allowlisted users get 404 on /scripture.
# BADWR_SCRIPTURE_MODULE_ADMIN_EMAILS=you@example.com
# Local only (next dev): skip allowlist; still requires sign-in. Never enable in production.
# BADWR_SCRIPTURE_MODULE_LOCAL_DEV=1
# Optional (dev): hide the access-denied debug JSON panel — set to 0 to suppress
# BADWR_SCRIPTURE_MODULE_ACCESS_DEBUG=0

# Optional — SOAPS / prayer / share / BADWR week boundary (Sun 00:00–Sat, calendar in this TZ). Default: America/Chicago
# NEXT_PUBLIC_PILLAR_WEEK_TIMEZONE=America/New_York

# Optional — Ask AI
# OPENAI_API_KEY=

# Optional — group invite emails (Resend)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=

# Optional — Capacitor native shell: override WebView URL (defaults to NEXT_PUBLIC_SITE_URL, then VERCEL_URL)
# CAPACITOR_SERVER_URL=https://your-production-domain.com
# CAPACITOR_APP_ID=app.badwr.beadiscipleworthreproducing
# CAPACITOR_APP_NAME=BADWR
